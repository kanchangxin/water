<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <Button
                android:id="@+id/backBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←"
                android:textSize="24sp"
                android:background="@drawable/btn_transparent"
                android:padding="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="高级设置"
                android:textSize="28sp"
                android:textColor="@color/white"
                android:layout_marginLeft="16dp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 提醒设置卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏰ 提醒设置"
                android:textSize="20sp"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- 提醒间隔 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="提醒间隔"
                    android:textSize="16sp"
                    android:textColor="@color/textPrimary" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <Button
                        android:id="@+id/decreaseInterval"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="-"
                        android:textSize="20sp"
                        android:background="@drawable/btn_secondary"
                        android:textColor="@color/primary" />

                    <EditText
                        android:id="@+id/intervalInput"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="20"
                        android:textSize="20sp"
                        android:textColor="@color/textPrimary"
                        android:gravity="center"
                        android:inputType="number"
                        android:background="@drawable/edittext_background"
                        android:padding="8dp"
                        android:layout_marginLeft="8dp"
                        android:layout_marginRight="8dp" />

                    <Button
                        android:id="@+id/increaseInterval"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="+"
                        android:textSize="20sp"
                        android:background="@drawable/btn_secondary"
                        android:textColor="@color/primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="分钟"
                        android:textSize="16sp"
                        android:textColor="@color/textSecondary" />
                </LinearLayout>
            </LinearLayout>

            <!-- 提醒铃声 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="提醒铃声"
                    android:textSize="16sp"
                    android:textColor="@color/textPrimary" />

                <Button
                    android:id="@+id/ringtoneBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="选择铃声"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:background="@drawable/btn_primary"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

                <Button
                    android:id="@+id/previewRingtone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▶"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:background="@drawable/btn_primary"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:layout_marginLeft="8dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/ringtoneName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="默认铃声"
                android:textSize="14sp"
                android:textColor="@color/textSecondary"
                android:layout_marginLeft="8dp"
                android:layout_marginBottom="16dp" />

            <!-- 个性化提示 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬 个性化提示"
                android:textSize="18sp"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/customMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="例如：该喝水啦！"
                android:textSize="16sp"
                android:textColor="@color/textPrimary"
                android:background="@drawable/edittext_background"
                android:padding="12dp"
                android:inputType="text"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/customMessageSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="提醒时显示的标题"
                android:textSize="12sp"
                android:textColor="@color/textLight" />

            <EditText
                android:id="@+id/customMessageSub2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="例如：站起来活动一下，喝杯水吧～"
                android:textSize="16sp"
                android:textColor="@color/textPrimary"
                android:background="@drawable/edittext_background"
                android:padding="12dp"
                android:inputType="text"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="提醒时显示的内容"
                android:textSize="12sp"
                android:textColor="@color/textLight" />
        </LinearLayout>

        <!-- 勿扰时段卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🌙 勿扰时段"
                    android:textSize="20sp"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/dndSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="开启后，在指定时段内不会发送提醒"
                android:textSize="14sp"
                android:textColor="@color/textSecondary"
                android:layout_marginBottom="16dp" />

            <!-- 时段1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/cardBackground"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="夜间免打扰"
                    android:textSize="16sp"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="从"
                        android:textSize="14sp"
                        android:textColor="@color/textSecondary" />

                    <Button
                        android:id="@+id/nightStartTimeBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="22:00"
                        android:textSize="14sp"
                        android:textColor="@color/primary"
                        android:background="@drawable/btn_secondary"
                        android:layout_marginLeft="8dp"
                        android:layout_marginRight="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="到"
                        android:textSize="14sp"
                        android:textColor="@color/textSecondary" />

                    <Button
                        android:id="@+id/nightEndTimeBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="07:00"
                        android:textSize="14sp"
                        android:textColor="@color/primary"
                        android:background="@drawable/btn_secondary"
                        android:layout_marginLeft="8dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 时段2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/cardBackground"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="午休免打扰"
                    android:textSize="16sp"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="从"
                        android:textSize="14sp"
                        android:textColor="@color/textSecondary" />

                    <Button
                        android:id="@+id/napStartTimeBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12:00"
                        android:textSize="14sp"
                        android:textColor="@color/primary"
                        android:background="@drawable/btn_secondary"
                        android:layout_marginLeft="8dp"
                        android:layout_marginRight="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="到"
                        android:textSize="14sp"
                        android:textColor="@color/textSecondary" />

                    <Button
                        android:id="@+id/napEndTimeBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="14:00"
                        android:textSize="14sp"
                        android:textColor="@color/primary"
                        android:background="@drawable/btn_secondary"
                        android:layout_marginLeft="8dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 帮助与支持卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="❓ 帮助与支持"
                android:textSize="20sp"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/testBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔔 测试提醒"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:background="@drawable/btn_primary"
                android:padding="12dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/helpBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="查看权限设置帮助"
                android:textSize="16sp"
                android:textColor="@color/primary"
                android:background="@drawable/btn_secondary"
                android:padding="12dp" />
        </LinearLayout>

        <!-- 保存按钮 -->
        <Button
            android:id="@+id/saveBtn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="✓ 保存设置"
            android:textSize="18sp"
            android:textColor="@color/white"
            android:background="@drawable/btn_success"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp" />
    </LinearLayout>
</ScrollView>
