<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/background_gradient"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="32dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💧"
            android:textSize="48sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="喝水提醒"
            android:textSize="32sp"
            android:textColor="@color/white"
            android:layout_marginLeft="16dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/timer_background"
        android:padding="32dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/timer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="20:00"
            android:textSize="56sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="提醒间隔:"
            android:textSize="18sp"
            android:textColor="@color/white" />

        <EditText
            android:id="@+id/interval"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:text="20"
            android:textSize="24sp"
            android:textColor="@color/textPrimary"
            android:background="@drawable/edittext_background"
            android:padding="8dp"
            android:gravity="center"
            android:inputType="number"
            android:layout_marginLeft="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="分钟"
            android:textSize="18sp"
            android:textColor="@color/white"
            android:layout_marginLeft="8dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="提醒铃声:"
            android:textSize="18sp"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/ringtoneBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="选择铃声"
            android:textSize="16sp"
            android:textColor="@color/textPrimary"
            android:background="@drawable/btn_secondary"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginLeft="8dp" />

        <TextView
            android:id="@+id/ringtoneName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="默认铃声"
            android:textSize="16sp"
            android:textColor="@color/textSecondary"
            android:layout_marginLeft="8dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/startBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="开始"
            android:textSize="18sp"
            android:textColor="@color/white"
            android:background="@drawable/btn_primary"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp" />

        <Button
            android:id="@+id/pauseBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="暂停"
            android:textSize="18sp"
            android:textColor="@color/textPrimary"
            android:background="@drawable/btn_secondary"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginLeft="16dp" />

        <Button
            android:id="@+id/resetBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="重置"
            android:textSize="18sp"
            android:textColor="@color/white"
            android:background="@drawable/btn_danger"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginLeft="16dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/testBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="测试提醒"
            android:textSize="18sp"
            android:textColor="@color/white"
            android:background="@drawable/btn_success"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp" />

        <Button
            android:id="@+id/test1minBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1分钟测试"
            android:textSize="18sp"
            android:textColor="@color/textPrimary"
            android:background="@drawable/btn_secondary"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginLeft="16dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="24dp">

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="提醒未启动"
            android:textSize="18sp"
            android:textColor="@color/textPrimary"
            android:background="@color/statusInactive"
            android:padding="12dp"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/lastDrank"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="上次喝水: 暂无记录"
            android:textSize="16sp"
            android:textColor="@color/textSecondary"
            android:background="@color/cardBackground"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/drankBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="我喝完了"
            android:textSize="20sp"
            android:textColor="@color/white"
            android:background="@drawable/btn_success"
            android:padding="16dp" />
    </LinearLayout>

</LinearLayout>
